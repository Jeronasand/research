{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-preview.jeronasand.cn/schemas/research-pending-tasks.schema.json",
  "title": "Research Pending Tasks",
  "type": "object",
  "required": [
    "schemaVersion",
    "items"
  ],
  "properties": {
    "schemaVersion": {
      "const": "research-pending-tasks/v1"
    },
    "updatedAt": {
      "type": "string",
      "description": "YYYY-MM-DD"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "summary": {
          "type": "string"
        },
        "request": {
          "type": "string"
        },
        "expectedOutput": {
          "type": "string"
        },
        "targetPath": {
          "type": "string",
          "description": "Expected future package path, for example research/in-progress/<id>/"
        },
        "packagePath": {
          "type": "string",
          "description": "Optional pending preview package directory, for example research/pending/<id>/"
        },
        "entry": {
          "type": "string",
          "description": "Optional preview entry file inside packagePath. Defaults to index.html"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/input"
          }
        },
        "owner": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "description": "YYYY-MM-DD"
        },
        "updatedAt": {
          "type": "string",
          "description": "YYYY-MM-DD"
        }
      },
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "examples": [
            "local",
            "url",
            "note"
          ]
        },
        "label": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
