# Copy this file to .env.oss-dual-bucket-access in the installed skill directory.
# Keep real keys and tokens out of git.

# Login bucket: used only for authentication or session validation.
OSS_LOGIN_ENDPOINT=
OSS_LOGIN_BUCKET=
OSS_LOGIN_PREFIX=
OSS_LOGIN_ACCESS_KEY_ID=
OSS_LOGIN_ACCESS_KEY_SECRET=
OSS_LOGIN_STS_TOKEN=
OSS_LOGIN_STS_EXPIRES_AT=

# Data-source bucket: fill only after the access mode is confirmed with the user.
OSS_DATA_ENDPOINT=
OSS_DATA_BUCKET=
OSS_DATA_PREFIX=
OSS_DATA_ACCESS_MODE=
OSS_DATA_ACCESS_KEY_ID=
OSS_DATA_ACCESS_KEY_SECRET=
OSS_DATA_STS_TOKEN=
OSS_DATA_STS_EXPIRES_AT=

# Optional browser access settings for CORS or static website checks.
OSS_DATA_ALLOWED_ORIGIN=
OSS_DATA_ALLOWED_METHODS=
OSS_DATA_EXPOSED_HEADERS=
OSS_DATA_WEBSITE_DOMAIN=
